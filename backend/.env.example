MONGODB_URI=mongodb://localhost:27017/judaica-shop
JWT_SECRET=change-this-to-a-long-random-string
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Store identity (used in email templates)
STORE_NAME=פארך

# Email — generic SMTP, works with Brevo / SendGrid / Resend's SMTP relay or any SMTP provider
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="פארך <no-reply@yourstore.co.il>"

# Green Invoice (https://www.greeninvoice.co.il) — invoice/receipt issuance after payment
# GREEN_INVOICE_ENV=production switches from the sandbox API to the live one
GREEN_INVOICE_API_KEY=
GREEN_INVOICE_API_SECRET=
GREEN_INVOICE_ENV=sandbox
# 400 = חשבונית מס קבלה (tax invoice + receipt) — default for paid online orders
GREEN_INVOICE_DOC_TYPE=400
# 0 = VAT included/calculated (עוסק מורשה), 2 = VAT exempt (עוסק פטור)
GREEN_INVOICE_VAT_TYPE=0
